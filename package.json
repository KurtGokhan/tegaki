{
  "name": "handy-text",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Create hand-written text animations",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KurtGokhan/handy-text.git"
  },
  "bin": {
    "myapp": "./index.ts"
  },
  "imports": {
    "#*": "./*"
  },
  "license": "MIT",
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "compile": "bun build --compile --minify --outfile dist/myapp src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check",
    "test": "bun test",
    "prepare": "husky"
  },
  "dependencies": {
    "padrone": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
